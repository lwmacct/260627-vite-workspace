{
  "name": "@lwmacct/260627-vite-workspace",
  "version": "0.8.260628",
  "private": false,
  "description": "Vite helpers for local multi-package workspace development.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
